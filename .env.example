# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Email (Resend) — optional, logs to console without it
RESEND_API_KEY=re_your_api_key
EMAIL_FROM=Homebirth.com <hello@homebirth.com>

# Google Maps — optional, shows placeholder without it
NEXT_PUBLIC_GOOGLE_MAPS_KEY=your-google-maps-key

# Site URL (used in email templates)
NEXT_PUBLIC_SITE_URL=https://homebirth.com
